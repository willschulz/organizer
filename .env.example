# Copy this to /opt/organizer/.env on organizer-ct (or alongside main.py for
# local development). Loaded by systemd via EnvironmentFile= in
# organizer.service.

# Path to the SQLite DB file. Default: ./data/organizer.db relative to the
# working directory.
# ORGANIZER_DB_PATH=/opt/organizer/data/organizer.db

# Bind host and port for the FastAPI/uvicorn process.
# Tailscale Serve forwards 443 -> 127.0.0.1:8551 in production.
# ORGANIZER_HOST=127.0.0.1
# ORGANIZER_PORT=8551
